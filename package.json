{
  "name": "project-memory-cli",
  "version": "0.2.0",
  "description": "Local-first, Git-tracked project memory for AI coding agents. npm i -g project-memory-cli; CLI: project-memory.",
  "keywords": [
    "ai",
    "cli",
    "project-memory",
    "project-memory-cli",
    "project-structure",
    "agent",
    "scaffold",
    "claude",
    "cursor",
    "codex",
    "context",
    "tasks",
    "developer-tools"
  ],
  "homepage": "https://www.npmjs.com/package/project-memory-cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/JoelHayward/project-memory-cli.git"
  },
  "bugs": {
    "url": "https://github.com/JoelHayward/project-memory-cli/issues"
  },
  "author": "Joel Hayward",
  "license": "MIT",
  "type": "module",
  "bin": {
    "project-memory": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "SPEC.md",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "smoke": "node --test scripts/smoke.mjs",
    "e2e": "node scripts/e2e-audit.mjs",
    "test": "npm run build && npm run smoke && npm run e2e",
    "release:check": "node scripts/release-check.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
